// Populate dropdown menu
function populateDropdownMenu() {
    dropdownMenu.innerHTML = '';
    
    // Add search input
    const searchInput = document.createElement('input');
    searchInput.type = 'text';
    searchInput.placeholder = 'Search suppliers...';
    searchInput.style.cssText = `
        width: 100%;
        padding: 0.5rem;
        border: none;
        border-bottom: 1px solid #e5e7eb;
        outline: none;
        font-size: 0.9rem;
        box-sizing: border-box;
    `;
    dropdownMenu.appendChild(searchInput);
    
    // Filter and display suppliers
    function filterAndDisplaySuppliers(searchTerm = '') {
        const filteredSuppliers = suppliersWithLogos.filter(supplier =>
            supplier.name.toLowerCase().includes(searchTerm.toLowerCase())
        );
        
        // Remove existing options
        const existingOptions = dropdownMenu.querySelectorAll('.supplier-option');
        existingOptions.forEach(option => option.remove());
        
        if (filteredSuppliers.length === 0) {
            const noResults = document.createElement('div');
            noResults.className = 'supplier-option';
            noResults.style.cssText = `
                padding: 0.75rem;
                color: #6b7280;
                font-style: italic;
                text-align: center;
            `;
            noResults.textContent = 'No suppliers found';
            dropdownMenu.appendChild(noResults);
            return;
        }
        
        filteredSuppliers.forEach(supplier => {
            const option = document.createElement('div');
            option.className = 'supplier-option';
            option.dataset.supplierId = supplier.id;
            option.dataset.supplierName = supplier.name;
            option.style.cssText = `
                padding: 0.75rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                transition: background-color 0.15s ease;
                border-bottom: 1px solid #f3f4f6;
            `;
            
            option.innerHTML = `
                <div style="position: relative; flex-shrink: 0;">
                    <img src="${supplier.logoPath}" 
                         alt="${supplier.name}" 
                         style="width: 28px; height: 28px; border-radius: 4px; object-fit: cover; border: 1px solid #e5e7eb;"
                         onerror="this.src='/static/vendor-logos/default.png'; this.style.opacity='0.5';">
                </div>
                <div>
                    <div style="font-weight: 500; color: #374151; font-size: 0.95rem;">${supplier.name}</div>
                    <div style="font-size: 0.8rem; color: #6b7280;">ID: ${supplier.id}</div>
                </div>
            `;
            
            option.addEventListener('mouseenter', () => {
                option.style.backgroundColor = '#f3f4f6';
            });
            
            option.addEventListener('mouseleave', () => {
                option.style.backgroundColor = 'transparent';
            });
            
            option.addEventListener('click', (e) => {
                e.stopPropagation();
                selectSupplier(supplier);
                closeDropdown();
            });
            
            dropdownMenu.appendChild(option);
        });
    }
    
    // Initial population
    filterAndDisplaySuppliers();
    
    // Search functionality
    searchInput.addEventListener('input', (e) => {
        filterAndDisplaySuppliers(e.target.value);
    });
    
    // Focus search input when dropdown opens
    setTimeout(() => {
        searchInput.focus();
    }, 100);
}

