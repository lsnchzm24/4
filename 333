grid.appendChild(wrap);
};
reader.readAsDataURL(file);
}

function removeClaimPhoto(index) {
claimPendingPhotos[index] = null;
const el = document.getElementById(`claim-thumb-${index}`);
if (el) el.remove();
}

async function uploadClaimPhotos(claimId) {
const toUpload = claimPendingPhotos.filter(f => f !== null);
if (!toUpload.length) return;
for (const file of toUpload) {
const fd = new FormData();
fd.append(‘photo’, file);
try {
await fetch(`/api/photos/upload/claim/${claimId}`, { method: ‘POST’, body: fd });
} catch (err) {
console.error(‘Claim photo upload failed:’, err);
}
}
claimPendingPhotos = [];
const grid = document.getElementById(‘claimPhotoPreviewGrid’);
if (grid) grid.innerHTML = ‘’;
}

