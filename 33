function aggregateEOLFindings(findings) {
const aggregatedMap = new Map();

```
findings.forEach(finding => {
    const key = finding.description?.trim().toLowerCase() || 'unknown';
    
    if (aggregatedMap.has(key)) {
        const existing = aggregatedMap.get(key);
        existing.count++;
        existing.instances.push(finding);
        
        // Keep the most recent date and its shiftID
        if (new Date(finding.dateRecorded) > new Date(existing.dateRecorded)) {
            existing.dateRecorded = finding.dateRecorded;
            existing.shiftID = finding.shiftID;
        }
        
        // Collect all unique ECART numbers
        if (finding.ecartNumber && !existing.ecartNumbers.includes(finding.ecartNumber)) {
            existing.ecartNumbers.push(finding.ecartNumber);
        }
        
        // Collect all unique sides
        if (finding.side && !existing.sides.includes(finding.side)) {
            existing.sides.push(finding.side);
        }
        
        // Collect all unique cost center locations
        if (finding.costCenterLocation && finding.costCenterLocation !== 'N/A' && !existing.costCenterLocations.includes(finding.costCenterLocation)) {
            existing.costCenterLocations.push(finding.costCenterLocation);
        }

        // Collect all unique additional notes
        if (finding.additionalNotes && finding.additionalNotes.trim() !== '' && !existing.allNotes.includes(finding.additionalNotes.trim())) {
            existing.allNotes.push(finding.additionalNotes.trim());
        }
    } else {
        aggregatedMap.set(key, {
            ...finding,
            count: 1,
            instances: [finding],
            ecartNumbers: finding.ecartNumber ? [finding.ecartNumber] : [],
            sides: finding.side ? [finding.side] : [],
            costCenterLocations: finding.costCenterLocation && finding.costCenterLocation !== 'N/A' ? [finding.costCenterLocation] : [],
            allNotes: finding.additionalNotes && finding.additionalNotes.trim() !== '' ? [finding.additionalNotes.trim()] : [],
            additionalNotes: finding.additionalNotes || ''
        });
    }
});

return Array.from(aggregatedMap.values())
    .sort((a, b) => {
        if (a.count !== b.count) {
            return b.count - a.count;
        }
        return new Date(b.dateRecorded) - new Date(a.dateRecorded);
    });
