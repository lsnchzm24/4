            // Mark expiring alerts so the renderer can style them differently
            expiringAlerts.forEach(alert => { alert.isExpiring = true; });
            
            // Filter out duplicates (an alert could be in both lists)
            const activeIds = new Set(activeAlerts.map(a => a.idQA));
            const uniqueExpiring = expiringAlerts.filter(a => !activeIds.has(a.idQA));
            
            // Merge: active alerts first, then expiring alerts
            const combinedAlerts = [...activeAlerts, ...uniqueExpiring];
            
            if (loadingElement) {
                loadingElement.style.display = 'none';
