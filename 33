            severity = parseInt(count) >= 10 ? 'High' : parseInt(count) >= 3 ? 'Medium' : 'Low';
        }
        break;
        
    case 'Scrap Report':
        details = `Reason: ${element.dataset.reason || 'Unknown'}, Report ID: ${element.dataset.reportId || 'N/A'}`;
        severity = 'Medium';
        break;
        
    case 'Supplier Containment':
        details = `Supplier: ${element.dataset.supplier || 'Unknown'}, Defect Rate: ${element.dataset.defectRate || '0'}%, Action: ${element.dataset.actionTaken || 'N/A'}`;
        const defectRate = parseFloat(element.dataset.defectRate || '0');
        severity = defectRate > 5 ? 'High' : defectRate > 2 ? 'Medium' : 'Low';
        break;
        
    case 'Quality Alert':
        details = `Alert ID: ${element.dataset.alertId || 'Unknown'}, Authorization: ${element.dataset.authorization || 'N/A'}`;
        severity = 'High';
        break;
        
    case 'MRB Part':
        details = `Part: ${element.dataset.partNumber || 'Unknown'}, Reason: ${element.dataset.quarantineReason || 'Unknown'}, Age: ${element.dataset.age || '0'} days`;
        const age = parseInt(element.dataset.age || '0');
        severity = age > 14 ? 'High' : age > 7 ? 'Medium' : 'Low';
        break;
        
    default:
        details = 'Quality issue requires attention';
        break;
}

const qualityData = {
    type: itemType,
    description: description,
    details: details,
    severity: severity,
    department: 'Quality'
};

meetingActions.captureItem('quality_issue', qualityData);
