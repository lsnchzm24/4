}

function updateTop3MonthLabel() {
var label = document.getElementById(‘eol-top3-month-label’);
if (label) {
label.textContent = eolTop3CurrentMonth.toLocaleDateString(‘en-US’, { month: ‘long’, year: ‘numeric’ });
}
}

function renderTop3EOLFindings() {
var container = document.getElementById(‘eol-top3-cards’);
if (!container) return;
var targetMonth = eolTop3CurrentMonth.getMonth();
var targetYear = eolTop3CurrentMonth.getFullYear();
var monthFindings = eolAllFindingsCache.filter(function(f) {
var d = new Date(f.dateRecorded);
return d.getMonth() === targetMonth && d.getFullYear() === targetYear;
});
var aggMap = {};
monthFindings.forEach(function(f) {
var key = (f.description || ‘Unknown’).trim().toUpperCase();
if (aggMap[key]) { aggMap[key].count++; }
else { aggMap[key] = { description: f.description || ‘Unknown’, count: 1 }; }
});
var top3 = Object.values(aggMap).sort(function(a, b) { return b.count - a.count; }).slice(0, 3);
if (top3.length === 0) {
container.innerHTML = ‘<div class="eol-top3-empty">No EOL findings for this month</div>’;
return;
}
container.innerHTML = ‘’;
top3.forEach(function(item, index) {
var card = document.createElement(‘div’);
card.className = ‘eol-top3-card’;
var pdcaKey = ‘pdca_’ + targetYear + ‘*’ + targetMonth + ’*’ + item.description.trim().toUpperCase().replace(/\s+/g, ‘_’);
var isChecked = false;
try { isChecked = localStorage.getItem(pdcaKey) === ‘true’; } catch(e) {}
card.innerHTML =
‘<div class="eol-top3-rank">#’ + (index + 1) + ‘</div>’ +
‘<div class="eol-top3-issue-name">’ + escapeHtml(item.description) + ‘</div>’ +
‘<div class="eol-top3-count-row">’ +
‘<div class="eol-top3-count"><i class="fas fa-redo-alt"></i> ’ + item.count + ’ occurrence’ + (item.count !== 1 ? ‘s’ : ‘’) + ‘</div>’ +
‘<label class="eol-top3-pdca ' + (isChecked ? 'checked' : '') + '" onclick="event.stopPropagation();">’ +
‘<input type=“checkbox” ’ + (isChecked ? ‘checked’ : ‘’) + ’ onchange=“togglePDCA(this, '’ + pdcaKey + ‘')”>’ +
‘<span class="eol-top3-pdca-label">PDCA Opened?</span>’ +
‘</label>’ +
‘</div>’;
container.appendChild(card);
});
}

function togglePDCA(checkbox, key) {
var label = checkbox.closest(’.eol-top3-pdca’);
if (checkbox.checked) {
label.classList.add(‘checked’);
try { localStorage.setItem(key, ‘true’); } catch(e) {}
} else {
label.classList.remove(‘checked’);
try { localStorage.removeItem(key); } catch(e) {}
}
}

function fetchMonthlyEOLFindings() {
var targetMonth = eolTop3CurrentMonth.getMonth() + 1;
var targetYear = eolTop3CurrentMonth.getFullYear();
fetch(’/api/quality/eol-findings/monthly?month=’ + targetMonth + ‘&year=’ + targetYear)
.then(function(response) {
if (response.ok) return response.json();
throw new Error(‘not ok’);
})
.then(function(data) {
if (Array.isArray(data)) {
eolAllFindingsCache = data;
renderTop3EOLFindings();
}
})
.catch(function(e) {
console.log(‘Monthly EOL endpoint not available, using cached data’);
renderTop3EOLFindings();
});
}

